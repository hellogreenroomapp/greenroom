rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function brandMemberDocId(brandId) {
      return brandId + '_' + request.auth.uid;
    }

    // Legacy member doc id: {userId}_{brandId}
    function legacyBrandMemberDocId(brandId) {
      return request.auth.uid + '_' + brandId;
    }

    function isBrandOwner(brandId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/brands/$(brandId)).data.ownerId == request.auth.uid;
    }

    function activeBrandMemberRecord(memberId, brandId) {
      let path = /databases/$(database)/documents/brandMembers/$(memberId);
      return exists(path) &&
        get(path).data.userId == request.auth.uid &&
        get(path).data.brandId == brandId &&
        get(path).data.status == 'active';
    }

    // Active brand member — canonical {brandId}_{userId} or legacy {userId}_{brandId}
    function hasActiveMembership(brandId) {
      return activeBrandMemberRecord(brandMemberDocId(brandId), brandId) ||
        activeBrandMemberRecord(legacyBrandMemberDocId(brandId), brandId);
    }

    function isBrandMember(brandId) {
      return request.auth != null && (
        isBrandOwner(brandId) || hasActiveMembership(brandId)
      );
    }
    
    function isBrandOwnerOrAdmin(brandId) {
      return request.auth != null && (
        isBrandOwner(brandId) ||
        (
          hasActiveMembership(brandId) &&
          (
            (
              activeBrandMemberRecord(brandMemberDocId(brandId), brandId) &&
              get(/databases/$(database)/documents/brandMembers/$(brandMemberDocId(brandId))).data.role in ['owner', 'admin']
            ) ||
            (
              activeBrandMemberRecord(legacyBrandMemberDocId(brandId), brandId) &&
              get(/databases/$(database)/documents/brandMembers/$(legacyBrandMemberDocId(brandId))).data.role in ['owner', 'admin']
            )
          )
        )
      );
    }
    
    // Helper function to extract userId from document ID (format: userId_brandId)
    function getUserIdFromDocId(docId) {
      return docId.split('_')[0];
    }
    
    // Helper function to extract brandId from document ID (format: userId_brandId)
    function getBrandIdFromDocId(docId) {
      return docId.split('_')[1];
    }

    // Collection: brands
    match /brands/{brandId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        isBrandMember(brandId)
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && isBrandOwnerOrAdmin(brandId);
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Collection: brandMembers (preferred doc id: {brandId}_{userId})
    match /brandMembers/{memberId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isBrandOwner(resource.data.brandId) ||
        isBrandMember(resource.data.brandId)
      );
      allow create: if request.auth != null && (
        isBrandOwnerOrAdmin(request.resource.data.brandId) ||
        (
          request.resource.data.userId == request.auth.uid &&
          memberId == brandMemberDocId(request.resource.data.brandId) &&
          request.resource.data.status == 'active'
        )
      );
      allow update: if request.auth != null && (
        isBrandOwnerOrAdmin(resource.data.brandId) ||
        (
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.brandId == resource.data.brandId &&
          request.resource.data.status == 'active'
        )
      );
      allow delete: if request.auth != null && isBrandOwnerOrAdmin(resource.data.brandId);
    }

    // Collection: brandInvites
    match /brandInvites/{inviteId} {
      allow read: if request.auth != null && (
        resource.data.email == request.auth.token.email ||
        isBrandMember(resource.data.brandId)
      );
      allow create: if request.auth != null && isBrandOwnerOrAdmin(request.resource.data.brandId);
      allow update: if request.auth != null && (
        resource.data.email == request.auth.token.email ||
        isBrandOwnerOrAdmin(resource.data.brandId)
      );
      allow delete: if request.auth != null && isBrandOwnerOrAdmin(resource.data.brandId);
    }

    // Collection: projects (collections)
    match /projects/{projectId} {
      allow read: if request.auth != null && isBrandMember(resource.data.brandId);
      allow create: if request.auth != null && isBrandMember(request.resource.data.brandId);
      allow update, delete: if request.auth != null && isBrandOwnerOrAdmin(resource.data.brandId);
    }

    // Collection: products
    match /products/{productId} {
      allow read: if request.auth != null && isBrandMember(resource.data.brandId);
      allow create: if request.auth != null && isBrandMember(request.resource.data.brandId);
      allow update: if request.auth != null && isBrandMember(resource.data.brandId);
      allow delete: if request.auth != null && isBrandOwnerOrAdmin(resource.data.brandId);
    }

    // Collection: userProfiles
    match /userProfiles/{userId} {
      allow read: if request.auth != null && (
        resource.id == request.auth.uid ||
        (resource.data.keys().hasAny(['brandId']) && isBrandMember(resource.data.brandId))
      );
      allow create: if request.auth != null && request.resource.id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.id == request.auth.uid;
    }

    // GreenRoom platform keys (Klaviyo client secret) — Cloud Functions only
    match /platformConfig/{docId} {
      allow read, write: if false;
    }

    // OAuth PKCE state — server (Cloud Functions) only
    match /oauthStates/{stateId} {
      allow read, write: if false;
    }

    // Integration tokens — server only
    match /brandIntegrationSecrets/{docId} {
      allow read, write: if false;
    }

    // Synced marketing calendar rows (Klaviyo, Shopify, etc.)
    match /marketingEvents/{eventId} {
      allow read: if request.auth != null && isBrandMember(resource.data.brandId);
      allow write: if false;
    }

    // Klaviyo audience + cadence snapshot (read-only sync)
    match /marketingKlaviyoInsights/{brandId} {
      allow read: if request.auth != null && isBrandMember(brandId);
      allow write: if false;
    }

    // Collection: userRewards
    // Document ID format: {userId}_{brandId}
    match /userRewards/{docId} {
      // Read: own rewards, or any active member of the brand (leaderboard, team visibility)
      allow read: if request.auth != null && (
        getUserIdFromDocId(docId) == request.auth.uid ||
        isBrandMember(getBrandIdFromDocId(docId))
      );
      
      // Create: user can create their own rewards document (on first action)
      allow create: if request.auth != null && 
        getUserIdFromDocId(docId) == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.brandId == getBrandIdFromDocId(docId);
      
      // Update: user can update their own rewards document
      // Note: In production, consider moving point-awarding to cloud functions for security
      allow update: if request.auth != null && 
        getUserIdFromDocId(docId) == request.auth.uid &&
        // Ensure userId and brandId don't change
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        resource.data.brandId == request.resource.data.brandId;
      
      // Delete: not allowed (preserve reward history)
      allow delete: if false;
      
      // Subcollection: transactions
      match /transactions/{transactionId} {
        // Read: user can read their own transactions
        allow read: if request.auth != null && 
          getUserIdFromDocId(docId) == request.auth.uid;
        
        // Create: user can create their own transactions (MVP)
        // Note: In production, consider moving to cloud functions
        allow create: if request.auth != null && 
          getUserIdFromDocId(docId) == request.auth.uid &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.brandId == getBrandIdFromDocId(docId);
        
        // Update/Delete: never allowed (audit trail)
        allow update, delete: if false;
      }
    }
  }
}
